{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["api/**/*.ts", "server/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "server/node_modules"]
}
